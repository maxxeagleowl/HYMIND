# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone — https://app.pinecone.io
# Phase 3 RAG layer. Pipeline degrades gracefully if these are not set.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=hymind-research
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Serper — https://serper.dev/api-key
SERPER_API_KEY=
SERPER_SEARCH_URL=https://google.serper.dev/search

# NewsAPI — https://newsapi.org/account
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2

# Output directories
REPORT_OUTPUT_DIR=outputs
REPORT_ARCHIVE_DIR=reports

# Runtime settings
LOG_LEVEL=INFO
MAX_ARTICLES_PER_RUN=15
MAX_SEARCH_RESULTS=15

# API server — Phase 5 n8n integration
# Set a value to require x-api-key header on all /run-hymind requests.
# Leave empty to allow unauthenticated local development access.
HYMIND_API_KEY=
